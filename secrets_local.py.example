"""Local secrets for the roadmap app. NOT committed to version control.

Copy this file to `secrets_local.py` (drop the .example suffix) and fill in
your own values before starting the app. The app will refuse to start if
secrets_local.py is missing or has the default values.

To copy:
    cp secrets_local.py.example secrets_local.py

Then edit secrets_local.py and change BOTH values below to something only
you know.

(File is named secrets_local.py rather than secrets.py to avoid shadowing
Python's standard-library `secrets` module.)
"""

# The password required to enter editor mode. Anyone visiting the app gets
# viewer access without a password; clicking "Sign in" and providing this
# password unlocks editing for the session (30 days).
EDITOR_PASSWORD = "CHANGE_ME_BEFORE_STARTING"

# Flask session signing key. Any long random string works.
# Generate a fresh one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY = "CHANGE_ME_BEFORE_STARTING"
